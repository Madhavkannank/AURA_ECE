APP_NAME=Aura-ECE API
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

MONGO_URI=mongodb://localhost:27017
MONGO_DB=aura_ece

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_REASONING_MODEL=llama-3.3-70b-versatile
GROQ_LIGHT_MODEL=llama-3.1-8b-instant
GROQ_WHISPER_MODEL=whisper-large-v3

DEFAULT_REPORT_FREQUENCY=weekly
FALLBACK_PARENT_LANGUAGE=en
REPORT_SCHEDULER_ENABLED=false
REPORT_SCHEDULER_PERIOD=weekly
REPORT_SCHEDULER_INTERVAL_MINUTES=60
NOTES_STORAGE_PATH=data/notes
NOTES_MAX_CHARS=12000
NOTES_CHUNK_CHARS=3000

AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRE_MINUTES=480
AUTH_ISSUER=aura-ece
AUTH_AUDIENCE=aura-ece-clients
ALLOW_BOOTSTRAP_AUTH=true

FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=
FIREBASE_CREDENTIALS_PATH=
TEACHER_EMAIL_DOMAIN=
